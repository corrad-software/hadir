# =============================================================================
# Hadir — Production environment (Coolify / Docker)
# Copy to Coolify env vars on the API / worker / scheduler services.
# =============================================================================

# --- Laravel core ---
APP_NAME=Hadir
APP_ENV=production
APP_KEY=                          # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://hadir.sena.my

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

BCRYPT_ROUNDS=12

# --- Single-domain SPA auth (hadir.sena.my/api) ---
# Coolify routes: /api/* and /sanctum/* → Laravel, /* → Vue static
FRONTEND_URL=https://hadir.sena.my
SANCTUM_STATEFUL_DOMAINS=hadir.sena.my
SESSION_DOMAIN=hadir.sena.my

# Trust proxy: configured in bootstrap/app.php (trustProxies at *)

# --- Logging ---
LOG_CHANNEL=stderr
LOG_STACK=single
LOG_LEVEL=warning

# --- MySQL (same Coolify MySQL server, separate schemas) ---
# kedatangan  → Laravel utama (users, roles, HR, settings, dll.)
# sso_hadir   → SSO login (table `User`)
# Internal: mysql://mysql:<password>@pg4cgww0g0s8okwokk4kcgkc:3306/<schema>
#
# First deploy: set MYSQL_ROOT_PASSWORD (from Coolify MySQL root password, Runtime only).
# Entrypoint auto-grants mysql user access to kedatangan + sso_hadir. Remove after success.
# Manual fallback: run docker/mysql/grant-schemas.sql as root.
MYSQL_ROOT_USER=root
MYSQL_ROOT_PASSWORD=

DB_CONNECTION=mysql
DB_HOST=pg4cgww0g0s8okwokk4kcgkc
DB_PORT=3306
DB_DATABASE=kedatangan
DB_USERNAME=mysql
DB_PASSWORD=

SSO_DB_HOST=pg4cgww0g0s8okwokk4kcgkc
SSO_DB_PORT=3306
SSO_DB_DATABASE=sso_hadir
SSO_DB_USERNAME=mysql
SSO_DB_PASSWORD=

# --- PostgreSQL (attendance module — Coolify PostgreSQL service) ---
# Internal: postgres://postgres:<password>@wgkcss4g8k0g0wk8kw0g84ss:5432/hadir
ATTENDANCE_DB_HOST=wgkcss4g8k0g0wk8kw0g84ss
ATTENDANCE_DB_PORT=5432
ATTENDANCE_DB_DATABASE=hadir
ATTENDANCE_DB_USERNAME=postgres
ATTENDANCE_DB_PASSWORD=

# --- Session / queue / cache ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=public

# --- Mail (configure when ready) ---
MAIL_MAILER=log
MAIL_FROM_ADDRESS=hello@sena.my
MAIL_FROM_NAME="${APP_NAME}"

# --- Docker entrypoint (API service only) ---
RUN_MIGRATIONS=true
RUN_SEED=false

# --- Optional: first admin SSO user (set RUN_SEED=true once on first deploy) ---
# SSO_ADMIN_ID=00000000-0000-0000-0000-000000000001
# SSO_ADMIN_EMAIL=admin@sena.my
# SSO_ADMIN_NAME=Administrator
# SSO_ADMIN_PASSWORD=
# SSO_ADMIN_ROLE=admin

# --- Frontend build arg (Dockerfile.frontend / Coolify build) ---
# VITE_API_BASE_URL=https://hadir.sena.my
